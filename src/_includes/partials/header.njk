  <!-- ═════════════════ SITE HEADER ═════════════════ -->
  <header class="site-header">
    <div class="container row">
      <a class="brand" href="/">
        <img class="brand-mark" src="/images/logo-white.png" alt="" width="46" height="42" />
        wschód
      </a>

      <nav class="nav-primary" aria-label="Główna nawigacja">
        {%- for item in nav %}
        <a class="nav-link{% if item.cta %} nav-cta{% endif %}{% if page.url | startsWith(item.match) %} is-active{% endif %}" href="{{ item.url }}"{% if page.url | startsWith(item.match) %} aria-current="page"{% endif %}>{{ item.label }}</a>
        {%- endfor %}
      </nav>

      <div class="nav-actions">
        <a class="btn btn--ghost" href="{{ site.links.donate }}" target="_blank" rel="noopener">Wspieraj</a>
        <button class="nav-mobile-toggle" id="navToggle" aria-label="Otwórz menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M4 7h16M4 12h16M4 17h16"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile nav -->
  <nav class="nav-mobile" id="navMobile" aria-label="Nawigacja mobilna">
    <button class="close" id="navClose" aria-label="Zamknij menu">×</button>
    <a href="/">strona główna</a>
    {%- for item in nav %}
    <a href="{{ item.url }}">{{ item.label }}</a>
    {%- endfor %}
  </nav>
