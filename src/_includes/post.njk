---
layout: base.njk
---
{%- set canonical = site.url + page.url %}
    <article>
      <section class="post-hero">
        <div class="container-narrow">
          <div class="kicker">
            <a class="back" href="/blog/"><span aria-hidden="true">←</span> wszystkie artykuły</a>
            {%- if category %}<span class="tag tag--coral"><span class="dot"></span>{{ category }}</span>{%- endif %}
          </div>
          <h1>{{ title }}</h1>
          {%- if excerpt %}
          <p class="lede">{{ excerpt }}</p>
          {%- endif %}
          <div class="post-meta">
            <span class="who">{{ author or "Redakcja WSCHÓD" }}</span>
            <span>{{ date | datePL }}</span>
            {%- if readingTime %}<span>{{ readingTime }} czytania</span>{%- endif %}
          </div>
        </div>
      </section>

      {%- if cover %}
      <div class="post-cover">
        <div class="container-narrow">
          <figure>
            <img src="{{ cover }}" alt="{{ coverAlt or title }}" />
          </figure>
          {%- if credit %}<figcaption>{{ credit }}</figcaption>{%- endif %}
        </div>
      </div>
      {%- endif %}

      <div class="post-body">
        <div class="container-narrow">
          <div class="post-layout">
            <div class="post-share" aria-label="Udostępnij">
              <a href="https://www.facebook.com/sharer/sharer.php?u={{ canonical | urlencode }}" target="_blank" rel="noopener" aria-label="Udostępnij na Facebooku">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-9h3l1-4h-4V7c0-1 .5-2 2-2h2V2c-.5 0-2-.2-3-.2-3 0-5 2-5 5V9H6v4h3v9h4z"/></svg>
              </a>
              <a href="https://twitter.com/intent/tweet?url={{ canonical | urlencode }}&text={{ title | urlencode }}" target="_blank" rel="noopener" aria-label="Udostępnij na X">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21.5l-7.5 8.57L23 22h-6.938l-4.84-6.32L5.6 22H2.34l8.02-9.166L1 2h7.09l4.376 5.79L18.244 2Zm-1.22 18h1.92L7.05 4H5l11.974 16Z"/></svg>
              </a>
              <button type="button" id="copyLink" data-url="{{ canonical }}" aria-label="Skopiuj link">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              </button>
            </div>

            <div>
              <div class="prose">
                {{ content | safe }}
              </div>

              <div class="post-footer">
                <div class="post-tags">
                  {%- if category %}<span class="tag tag--blue"><span class="dot"></span>{{ category }}</span>{%- endif %}
                  <span class="tag tag--peach">Inicjatywa WSCHÓD</span>
                </div>
                <a class="btn btn--coral" href="{{ site.links.join }}" target="_blank" rel="noopener">
                  Dołącz do ruchu <span class="arrow" aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      {%- if collections.posts.length > 1 %}
      <section class="section panel--cream post-more">
        <div class="container">
          <h2>Czytaj dalej</h2>
          <div class="blog-grid">
            {%- set tagColors = ["jade", "coral", "blue", "peach"] %}
            {%- set shown = 0 %}
            {%- for post in collections.posts %}
            {%- if post.url != page.url and shown < 3 %}
            {%- set shown = shown + 1 %}
            <article class="article-card reveal">
              <figure class="photo">
                <img src="{{ post.data.cover }}" alt="{{ post.data.coverAlt or post.data.title }}" loading="lazy" />
              </figure>
              <div class="body">
                <div><span class="tag tag--{{ tagColors[loop.index0 % 4] }}"><span class="dot"></span>{{ post.data.category }}</span></div>
                <h3>{{ post.data.title }}</h3>
                <p>{{ post.data.excerpt }}</p>
                <div class="meta"><span>{{ post.date | datePL }}</span><span>{{ post.data.readingTime }}</span></div>
                <div><a class="btn btn--ghost" href="{{ post.url }}" style="color:var(--ink);border-color:var(--rule);font-size:0.78rem;padding:0.5rem 1rem;">Czytaj <span class="arrow" aria-hidden="true">→</span></a></div>
              </div>
            </article>
            {%- endif %}
            {%- endfor %}
          </div>
        </div>
      </section>
      {%- endif %}
    </article>

    <script>
      document.getElementById("copyLink")?.addEventListener("click", async (e) => {
        const btn = e.currentTarget;
        try {
          await navigator.clipboard.writeText(btn.dataset.url);
          btn.style.background = "var(--jade)";
          btn.style.color = "var(--on-jade)";
          setTimeout(() => { btn.style.background = ""; btn.style.color = ""; }, 1400);
        } catch (err) { /* no-op */ }
      });
    </script>
